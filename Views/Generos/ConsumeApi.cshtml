@{
    ViewData["Title"] = "Consumir API REST de Géneros";
}

<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Géneros desde Servicio Web</h1>
            <p class="text-gray-600 ">Esta página consume la API REST interna <code>/api/generosapi</code> utilizando Javascript (fetch) puro.</p>
        </div>
        <button onclick="abrirModalCrear()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow">
            + Nuevo Género (Vía API)
        </button>
    </div>

    <!-- Contenedor para la tabla -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">ID</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Descripción</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Estado</th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Acciones</th>
                </tr>
            </thead>
            <tbody id="tablaGeneros" class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <!-- Los datos se insertarán aquí dinámicamente -->
                <tr>
                    <td colspan="4" class="px-6 py-4 text-center text-gray-500">Cargando datos desde la API...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal para Crear/Editar (Simplificado) -->
<div id="modalGenero" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50 flex items-center justify-center">
    <div class="relative p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="mt-3">
            <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white" id="modalTitle">Crear Nuevo Género</h3>
            <div class="mt-2">
                <form id="formGenero" onsubmit="guardarGenero(event)">
                    <input type="hidden" id="generoId" value="0">
                    
                    <div class="mb-4">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Descripción</label>
                        <input type="text" id="generoDescripcion" required class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline dark:bg-gray-700 dark:text-white dark:border-gray-600">
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Estado</label>
                        <select id="generoEstado" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline dark:bg-gray-700 dark:text-white dark:border-gray-600">
                            <option value="1">Activo</option>
                            <option value="0">Inactivo</option>
                        </select>
                    </div>

                    <div class="flex items-center justify-between mt-4">
                        <button type="button" onclick="cerrarModal()" class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400">Cancelar</button>
                        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Guardar mediante API</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiUrl = '/api/generosapi';

        // Cargar datos al iniciar
        document.addEventListener('DOMContentLoaded', () => {
            obtenerGeneros();
        });

        // GET: Obtener todos los géneros
        async function obtenerGeneros() {
            try {
                const response = await fetch(apiUrl);
                if (!response.ok) throw new Error('Error en la red');
                
                const generos = await response.json();
                renderizarTabla(generos);
            } catch (error) {
                console.error('Error obteniendo géneros:', error);
                document.getElementById('tablaGeneros').innerHTML = `
                    <tr><td colspan="4" class="px-6 py-4 text-center text-red-500">Error al cargar datos desde la API</td></tr>
                `;
            }
        }

        // Renderizar datos en la tabla HTML
        function renderizarTabla(generos) {
            const tbody = document.getElementById('tablaGeneros');
            tbody.innerHTML = ''; // Limpiar

            if (generos.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">No hay géneros. ¡Crea uno nuevo!</td></tr>';
                return;
            }

            generos.forEach(g => {
                const estadoBadge = g.estado === 1 
                    ? '<span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Activo</span>'
                    : '<span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Inactivo</span>';

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300">${g.id}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">${g.descripcion}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${estadoBadge}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <button onclick="eliminarGenero(${g.id})" class="text-red-600 hover:text-red-900 ml-3">Eliminar por API</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // POST: Guardar nuevo género
        async function guardarGenero(event) {
            event.preventDefault(); // Evitar recarga del form

            const descripcion = document.getElementById('generoDescripcion').value;
            const estado = parseInt(document.getElementById('generoEstado').value);

            const nuevoGenero = {
                descripcion: descripcion,
                estado: estado
            };

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(nuevoGenero)
                });

                if (response.ok) {
                    cerrarModal();
                    obtenerGeneros(); // Recargar la tabla
                } else {
                    alert("Error al guardar en la API");
                }
            } catch (error) {
                console.error('Error guardando:', error);
            }
        }

        // DELETE: Eliminar género
        async function eliminarGenero(id) {
            if (!confirm(`¿Estás seguro de que deseas eliminar este género (ID: ${id}) vía API?`)) return;

            try {
                const response = await fetch(`${apiUrl}/${id}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    // Si se elimina correctamente (o por cascada falla si está en uso, pero aquí suponemos que funciona)
                    obtenerGeneros(); // Recargar la tabla
                } else {
                    alert("Error al eliminar en la API. Puede que esté siendo usado en otras tablas.");
                }
            } catch (error) {
                console.error('Error eliminando:', error);
            }
        }

        /* Funciones del UI (Modal) */
        function abrirModalCrear() {
            document.getElementById('formGenero').reset();
            document.getElementById('generoId').value = "0";
            document.getElementById('modalTitle').innerText = "Crear Nuevo Género (POST API)";
            document.getElementById('modalGenero').classList.remove('hidden');
        }

        function cerrarModal() {
            document.getElementById('modalGenero').classList.add('hidden');
        }
    </script>
}
